# Groq API key — create one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Primary model (mandated by the assignment)
GROQ_MODEL=gemma2-9b-it

# Optional fallback / heavier-reasoning model
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Database — Postgres example:
#   DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/hcp_crm
# MySQL example:
#   DATABASE_URL=mysql+pymysql://user:password@localhost:3306/hcp_crm
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hcp_crm

# CORS origin for the React dev server
FRONTEND_ORIGIN=http://localhost:3000
